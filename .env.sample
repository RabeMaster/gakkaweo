# ============================================================
# 로컬 개발 환경변수 (.env)
# ============================================================

# 초기 시딩 (최초 SUPERADMIN 계정 자동 생성용, 이후부터 무시)
# 설정 시 8자 이상 필수. 보안상 최초 SUPERADMIN 생성 후 제거 권장
SEED_ADMIN_PASSWORD=INPUT_YOUR_INITIAL_ADMIN_PASSWORD

# PostgreSQL - DB_USER, DB_PASSWORD 필수
DB_HOST=localhost
DB_PORT=5432
DB_USER=INPUT_YOUR_DB_USER
DB_PASSWORD=INPUT_YOUR_DB_PASSWORD

# Redis - REDIS_PASSWORD 필수
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=INPUT_YOUR_REDIS_PASSWORD

# JWT - JWT_ACCESS_SECRET 필수 (Base64 인코딩 256bit 이상). expiration은 Duration 형식 (예: 30m, 7d, 1h)
JWT_ACCESS_SECRET=INPUT_YOUR_BASE64_ENCODED_256BIT_SECRET
JWT_ACCESS_EXPIRATION=30m
JWT_REFRESH_EXPIRATION=7d

# 쿠키 - COOKIE_DOMAIN 필수 (크로스 서브도메인 공유, 앞에 . 필수)
# COOKIE_SECURE: HTTPS에서만 쿠키 전송 (true/false). local=false, prod=true
COOKIE_SECURE=false
COOKIE_DOMAIN=

# OAuth - 전체 필수
OAUTH_KAKAO_CLIENT_ID=INPUT_YOUR_KAKAO_CLIENT_ID
OAUTH_KAKAO_CLIENT_SECRET=INPUT_YOUR_KAKAO_CLIENT_SECRET
OAUTH_GOOGLE_CLIENT_ID=INPUT_YOUR_GOOGLE_CLIENT_ID
OAUTH_GOOGLE_CLIENT_SECRET=INPUT_YOUR_GOOGLE_CLIENT_SECRET
OAUTH_NAVER_CLIENT_ID=INPUT_YOUR_NAVER_CLIENT_ID
OAUTH_NAVER_CLIENT_SECRET=INPUT_YOUR_NAVER_CLIENT_SECRET
# OAuth 인증 완료 후 FE로 돌려보낼 URL (공급자 콜백 URI 아님)
OAUTH_REDIRECT_URI=http://localhost:3000

# AI Service (AI_SERVICE_URL은 backend->ai 내부 호출 주소. prod는 docker 서비스명 사용)
AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://localhost:8000
# AI 호출 타임아웃. Duration 형식 (예: 3s, 500ms)
AI_SERVICE_TIMEOUT=3s

# 게임
# 클리어 인정 유사도 임계값(0~100, 이 값 이상이면 정답 처리)
SIMILARITY_THRESHOLD=95.0
# 힌트 활성화 유사도 임계값(이 값 이상 달성 시 힌트 패널 잠금 해제)
HINT_TRIGGER_THRESHOLD=60.0
# 힌트 최대 유사도 상한(요청자 bestSimilarity와 이 값 중 작은 쪽 기준 필터링)
HINT_MAX_SIMILARITY=90.0
# 힌트 최대 표시 개수
HINT_MAX_COUNT=5
# 프로필 이미지 저장 경로. prod는 docker 볼륨 마운트 지점
UPLOAD_PROFILE_DIR=./uploads/profiles

# SSE 동시 연결 상한 (랭킹 스트림). 초과 시 SSE_MAX_CONNECTIONS 에러
SSE_MAX_CONNECTIONS=500

# Rate Limiting (분당 요청 수. 그룹별 적용 경로: GUESS=/daily/guess, READ=GET 엔드포인트, SSE=/ranking/stream, AUTH=/auth/**, ADMIN=/admin/**)
RATE_LIMIT_GUESS=40
RATE_LIMIT_READ=120
RATE_LIMIT_SSE=10
RATE_LIMIT_AUTH=10
RATE_LIMIT_ADMIN=120
# 미사용 버킷 보관 시간(분). 이 시간 경과 후 cleanup 대상
RATE_LIMIT_BUCKET_EXPIRY=10
# 버킷 정리 주기(ms). 기본 5분
RATE_LIMIT_CLEANUP_INTERVAL_MS=300000

# Discord 웹훅 (자정 스케줄러/어드민 감사/서버 오류 공유. 미설정 시 전송 스킵)
DISCORD_WEBHOOK_URL=
# Discord HTTP 타임아웃. Duration 형식 (예: 3s, 500ms)
DISCORD_WEBHOOK_TIMEOUT=3s
# HIGH 레벨 알림 시 멘션할 Discord Role ID (숫자 snowflake). 미설정 시 멘션 없이 전송
DISCORD_MENTION_ROLE_ID=

# 어드민 감사 로그 알림 on/off (true/false). 모든 관리자 감사 액션 전송
AUDIT_ALERT_ENABLED=true
# 서버 오류(500) 알림 on/off (true/false). GlobalExceptionHandler 경로만
ERROR_ALERT_ENABLED=true
# 동일 예외·경로 조합 중복 알림 억제 쿨다운. Duration 형식 (예: 5m, 30s, 1h)
ERROR_ALERT_COOLDOWN=5m
# 중복 억제 캐시 정리 주기(ms). 기본 5분, 통상 조정 불필요
NOTIFICATION_DEDUP_CLEANUP_INTERVAL_MS=300000

# Redis 키 누수 정리 스케줄러 (6h 간격, 04:30/10:30/16:30/22:30 KST)
REDIS_CLEANUP_ENABLED=true
REDIS_CLEANUP_SCAN_BATCH_SIZE=500
# N일 이상 오래된 ranking/ranking_detail 키 삭제 (자정 스케줄러 영역 보호 위해 최소 2)
REDIS_CLEANUP_PURGE_OLDER_THAN_DAYS=2
REDIS_CLEANUP_NOTIFY_ON_ZERO=false

# OpenAPI (CI 전용, 로컬에서는 false 유지)
APP_OPENAPI_DOCS_MODE=false

# Monitoring (Actuator 관리 포트. Prometheus가 스크래핑하는 대상)
MANAGEMENT_PORT=9090
# Grafana 관리자 계정 (로컬에서만 사용, 기본값 admin/admin)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# 서버
SERVER_PORT=8080
# Nginx 등 프록시 뒤 X-Forwarded-* 헤더 처리 (local=none, prod=native)
FORWARD_HEADERS_STRATEGY=none
# com.gakkaweo.backend 패키지 로그 레벨
LOG_LEVEL=DEBUG

# JVM
JAVA_OPTS=
