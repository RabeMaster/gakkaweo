root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
quote_type = double

[*.{js,jsx,ts,tsx,json,html,css}]
indent_style = space
indent_size = 2

[*.java]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.{md,yml,yaml}]
indent_style = space
indent_size = 2
