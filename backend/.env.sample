# PostgreSQL Settings
DB_USER=INPUT_YOUR_DB_USER
DB_PASSWORD=INPUT_YOUR_DB_PASSWORD
DB_PORT=5432

# Redis Settings
REDIS_PASSWORD=INPUT_YOUR_REDIS_PASSWORD
REDIS_PORT=6379

# JWT Settings
JWT_ACCESS_SECRET=INPUT_YOUR_BASE64_ENCODED_256BIT_SECRET
JWT_ACCESS_EXPIRATION=30m
JWT_REFRESH_EXPIRATION=7d
COOKIE_SECURE=false

# OAuth Settings
OAUTH_KAKAO_CLIENT_ID=INPUT_YOUR_KAKAO_CLIENT_ID
OAUTH_KAKAO_CLIENT_SECRET=INPUT_YOUR_KAKAO_CLIENT_SECRET
OAUTH_GOOGLE_CLIENT_ID=INPUT_YOUR_GOOGLE_CLIENT_ID
OAUTH_GOOGLE_CLIENT_SECRET=INPUT_YOUR_GOOGLE_CLIENT_SECRET
OAUTH_NAVER_CLIENT_ID=INPUT_YOUR_NAVER_CLIENT_ID
OAUTH_NAVER_CLIENT_SECRET=INPUT_YOUR_NAVER_CLIENT_SECRET
OAUTH_REDIRECT_URI=http://localhost:3000

# AI Service Settings
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT=3s
