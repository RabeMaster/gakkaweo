set -e

# GitHub Desktop의 MinGW에는 gradlew가 필요시하는 cygpath가 없으므로, cygpath 명령어를 대체하게끔 설정
if ! command -v cygpath &>/dev/null; then
  cygpath() { echo "${@: -1}"; }
  export -f cygpath
fi

# 프론트엔드 린트 및 포맷
cd frontend && ./node_modules/.bin/lint-staged
cd ..

# 백엔드 린트 및 포맷 (staged 파일만 재스테이지)
STAGED_JAVA=$(git diff --cached --name-only --diff-filter=ACMR | grep 'backend/src/.*\.java$' || true)
if [ -n "$STAGED_JAVA" ]; then
  cd backend && ./gradlew spotlessApply -q && cd ..
  echo "$STAGED_JAVA" | while IFS= read -r file; do
    git add -- "$file"
  done
fi

# AI 서비스(파이썬) 린트 및 포맷 (staged 파일만 재스테이지)
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACMR | grep 'ai-service/.*\.py$' || true)
if [ -n "$STAGED_PY" ]; then
  ./ai-service/.venv/Scripts/ruff check --fix ai-service/
  ./ai-service/.venv/Scripts/ruff format ai-service/
  echo "$STAGED_PY" | while IFS= read -r file; do
    git add -- "$file"
  done
fi
